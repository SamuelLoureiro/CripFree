<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D"
    tools:context=".MainActivity">

    <!-- BT status badge (top) -->
    <LinearLayout
        android:id="@+id/statusBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="6dp"
        android:background="@drawable/bg_badge"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="52dp">

        <View
            android:layout_width="7dp"
            android:layout_height="7dp"
            android:background="@drawable/bg_dot_blue"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BT READY"
            android:textColor="#555555"
            android:textSize="10sp"
            android:letterSpacing="0.15"
            android:fontFamily="monospace" />

    </LinearLayout>

    <!-- Lock icon ring -->
    <FrameLayout
        android:id="@+id/iconRing"
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:background="@drawable/bg_ring"
        app:layout_constraintTop_toBottomOf="@id/statusBadge"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvTitle"
        android:layout_marginBottom="24dp">

        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_lock"
            app:tint="#606060" />

    </FrameLayout>

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DIGITAL VAULT"
        android:textColor="#EFEFEF"
        android:textSize="26sp"
        android:letterSpacing="0.08"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/iconRing"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvSubtitle" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AUTHENTICATION REQUIRED"
        android:textColor="#3A3A3A"
        android:textSize="10sp"
        android:letterSpacing="0.2"
        android:fontFamily="monospace"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="6dp" />

    <!-- Unlock button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/button"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:text="UNLOCK VAULT"
        android:textColor="#0D0D0D"
        android:textSize="13sp"
        android:letterSpacing="0.12"
        android:textStyle="bold"
        app:icon="@drawable/unlock"
        app:iconTint="#0D0D0D"
        app:iconSize="18dp"
        app:backgroundTint="#EFEFEF"
        app:cornerRadius="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/rstBtn"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="48dp"
        android:layout_marginBottom="12dp" />

    <!-- Reset connection button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/rstBtn"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:text="RESET CONNECTION"
        android:textColor="#444444"
        android:textSize="11sp"
        android:letterSpacing="0.1"
        app:icon="@drawable/ic_refresh"
        app:iconTint="#444444"
        app:iconSize="16dp"
        app:backgroundTint="@android:color/transparent"
        app:strokeColor="#222222"
        app:strokeWidth="1dp"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/button"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="52dp" />

</androidx.constraintlayout.widget.ConstraintLayout>